{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prism-browser",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-26",
  "assets": {
    "directory": "./dist/renderer",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "observability": {
    "enabled": true
  }
}
